{
  "name": "cashflow",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:worker": "wrangler pages dev dist --d1=cashflow=89694fbf-dbb5-4253-84a5-d6b6c53af612 --port=8788",
    "build": "vite build && npm run build:worker",
    "build:worker": "esbuild functions/_worker.js --bundle --outfile=dist/_worker.js --format=esm --platform=browser --external:__STATIC_CONTENT_MANIFEST",
    "preview": "vite preview",
    "db:migrate": "wrangler d1 execute cashflow --file=migrations/001_init.sql --local",
    "db:migrate:remote": "wrangler d1 execute cashflow --file=migrations/001_init.sql --remote",
    "check:encoding": "node tools/check-encoding.cjs"
  },
  "dependencies": {
    "hono": "^4.7.0",
    "lucide-react": "^1.17.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.1.0",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.0",
    "@vitejs/plugin-react": "^4.3.0",
    "tailwindcss": "^4.1.0",
    "vite": "^6.1.0",
    "wrangler": "^4.0.0"
  }
}
